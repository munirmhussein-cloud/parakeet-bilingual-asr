{
  "schema_version": "production_bronze_v3_silver_v3_silver_plus_v4_config_v1",
  "common": {
    "repo_root": "/content/parakeet-bilingual-asr",
    "drive_root": "/content/drive/MyDrive/parakeet-bilingual-asr",
    "lecture_root": "/content/drive/MyDrive/parakeet-bilingual-asr/production_a100/lectures/{lecture_id}",
    "log_root": "/content/drive/MyDrive/parakeet-bilingual-asr/production_a100/pipeline_logs"
  },
  "stages": {
    "bronze_v3": {
      "resource": "io",
      "max_workers": "auto",
      "cwd": "{repo_root}",
      "command": [
        "/bin/bash",
        "-lc",
        "set -euo pipefail; AUDIO=$(find '{lecture_root}' -type f \\( -iname '*.wav' -o -iname '*.mp3' -o -iname '*.m4a' -o -iname '*.flac' \\) ! -path '*/audio_views/*' | sort | head -n 1); test -n \"$AUDIO\"; python scripts/run_bronze_v3_production_lecture.py --repo-root '{repo_root}' --lecture-id '{lecture_id}' --audio \"$AUDIO\" --output-root '{lecture_root}/bronze_v3'"
      ],
      "expected_outputs": [
        "{lecture_root}/bronze_v3/{lecture_id}_bronze_v3_azure_whole.json",
        "{lecture_root}/bronze_v3/{lecture_id}_bronze_v3_azure_parent.jsonl"
      ]
    },
    "silver_v3": {
      "resource": "gpu",
      "max_workers": "auto",
      "cwd": "{repo_root}",
      "command": [
        "/bin/bash",
        "-lc",
        "set -euo pipefail; AUDIO=$(find '{lecture_root}' -type f \\( -iname '*.wav' -o -iname '*.mp3' -o -iname '*.m4a' -o -iname '*.flac' \\) ! -path '*/audio_views/*' | sort | head -n 1); test -n \"$AUDIO\"; python scripts/run_silver_v3_production_lecture.py --repo-root '{repo_root}' --lecture-id '{lecture_id}' --audio \"$AUDIO\" --silver-root '{lecture_root}/silver_v3' --view-workers 12"
      ],
      "expected_outputs": [
        "{lecture_root}/silver_v3/reconciled_fixed/{lecture_id}_silver_v3_fixed_segment_level.jsonl",
        "{lecture_root}/silver_v3/reconciled_fixed/{lecture_id}_silver_v3_fixed_quality_report.json"
      ]
    },
    "silver_plus_v4": {
      "resource": "cpu",
      "max_workers": "auto",
      "cwd": "{repo_root}",
      "command": [
        "/usr/bin/python3",
        "{repo_root}/scripts/run_silver_plus_v4_fifth_view_export_final.py",
        "--repo-root",
        "{repo_root}",
        "--silver-v3",
        "{lecture_root}/silver_v3/reconciled_fixed/{lecture_id}_silver_v3_fixed_segment_level.jsonl",
        "--azure-parent",
        "{lecture_root}/bronze_v3/{lecture_id}_bronze_v3_azure_parent.jsonl",
        "--gold",
        "{lecture_root}/silver_plus_v4/evaluation_reference/gold_v12_segments.jsonl",
        "--gold-eval-reference",
        "{lecture_root}/silver_plus_v4/evaluation_reference/gold_eval_reference.py",
        "--output-dir",
        "{lecture_root}/silver_plus_v4/fifth_view_integrated",
        "--output-prefix",
        "{lecture_id}_silver_plus_v4"
      ],
      "expected_outputs": [
        "{lecture_root}/silver_plus_v4/fifth_view_integrated/{lecture_id}_silver_plus_v4.zip",
        "{lecture_root}/silver_plus_v4/fifth_view_integrated/PACKAGE_MANIFEST.json",
        "{lecture_root}/silver_plus_v4/fifth_view_integrated/{lecture_id}_silver_plus_v4_run_report.json"
      ]
    }
  }
}

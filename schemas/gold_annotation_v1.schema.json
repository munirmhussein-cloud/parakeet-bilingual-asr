{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gold Annotation v1",
  "type": "object",
  "required": [
    "schema_version",
    "segment_id",
    "audio_filepath",
    "duration",
    "gold_text",
    "tokens"
  ],
  "properties": {
    "schema_version": { "const": "gold_annotation_v1" },
    "segment_id": { "type": "string" },
    "audio_filepath": { "type": "string" },
    "offset": { "type": "number", "minimum": 0 },
    "duration": { "type": "number", "exclusiveMinimum": 0 },
    "gold_text": { "type": "string" },
    "normalized_text": { "type": "string" },
    "primary_language": {
      "type": "string",
      "enum": ["eng", "ar", "mixed", "unknown"]
    },
    "contains_code_switching": { "type": "boolean" },
    "review_status": {
      "type": "string",
      "enum": ["draft", "reviewed", "approved", "rejected"]
    },
    "reviewer_id": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["index", "corrected_text", "selected_language"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "bronze_en": { "type": "string" },
          "bronze_ar": { "type": "string" },
          "corrected_text": { "type": "string" },
          "selected_language": {
            "type": "string",
            "enum": ["eng", "ar", "mixed", "noise", "unintelligible", "silence"]
          },
          "start_time": { "type": "number", "minimum": 0 },
          "end_time": { "type": "number", "minimum": 0 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "edit_status": {
            "type": "string",
            "enum": ["unchanged", "edited", "inserted", "deleted"]
          },
          "normalization_notes": { "type": "string" },
          "audit_history": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["timestamp", "field", "old_value", "new_value", "source"],
              "properties": {
                "timestamp": { "type": "string" },
                "reviewer_id": { "type": "string" },
                "field": { "type": "string" },
                "old_value": {},
                "new_value": {},
                "source": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
